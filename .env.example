# ─── Lovable Cloud / Supabase (auto-configured) ───
VITE_SUPABASE_PROJECT_ID="your-project-id"
VITE_SUPABASE_PUBLISHABLE_KEY="your-anon-key"
VITE_SUPABASE_URL="https://your-project-id.supabase.co"

# ─── Edge Function Secrets (set via Lovable Cloud secrets) ───
# LOVABLE_API_KEY       - AI gateway key for voice analysis & coaching
# SUPABASE_SERVICE_ROLE_KEY - Auto-configured, used for admin operations
# SUPABASE_ANON_KEY     - Auto-configured, used for auth validation
# SUPABASE_URL          - Auto-configured, Supabase project URL
# RESEND_API_KEY        - Email sending via Resend
